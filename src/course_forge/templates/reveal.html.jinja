    <script src="{{ base_url }}/js/mermaid.min.js" data-no-bundle></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            mermaid.initialize({
                startOnLoad: false,
                theme: 'default',
                securityLevel: 'loose',
                htmlLabels: false,
                fontFamily: 'Inter, system-ui, sans-serif',
            });
        });
    </script>
    <script src="{{ base_url }}/js/rough.min.js" data-no-bundle></script>
    <script src="{{ base_url }}/js/apply_sketch.js" data-no-bundle></script>
    <script src="{{ base_url }}/js/lucide.min.js" data-no-bundle></script>
    <script src="{{ base_url }}/js/ui.js" data-no-bundle></script>
    <script>
        const waitForNextFrame = () => new Promise(resolve => requestAnimationFrame(resolve));

        const initSlideUI = () => {
            if (!window.CourseForgeUI) {
                return;
            }

            window.CourseForgeUI.initCopyButtons();
            window.CourseForgeUI.initIcons();
        };

        const renderMermaidsInSlide = async (slide) => {
            if (!slide) {
                return;
            }

            const mermaids = slide.querySelectorAll('.mermaid');
            if (!mermaids.length) {
                return;
            }

            try {
                if (document.fonts?.ready) {
                    await document.fonts.ready;
                }

                await waitForNextFrame();
                await waitForNextFrame();

                for (const element of mermaids) {
                    if (element.dataset.mermaidRendered === 'true') {
                        continue;
                    }

                    await mermaid.run({
                        nodes: [element],
                    });
                    element.dataset.mermaidRendered = 'true';
                }
            } catch (err) {
                console.warn('Mermaid render failed', err);
            }
        };

        const updateMermaidDisplayBounds = (slide) => {
            const scope = slide || document;
            const displays = scope.querySelectorAll('.mermaid-display');

            for (const display of displays) {
                const rect = display.getBoundingClientRect();
                const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                const bottomGap = 24;
                const availableHeight = Math.max(160, Math.floor(viewportHeight - rect.top - bottomGap));
                display.style.setProperty('--mermaid-max-height', `${availableHeight}px`);
            }
        };

        const resetNativeLineNumbers = (pre) => {
            if (!pre?.classList.contains('line-numbers')) {
                return;
            }

            const existingRows = pre.querySelector('.line-numbers-rows');
            if (existingRows) {
                existingRows.remove();
            }
        };

        const highlightCodeInSlide = (slide) => {
            const scope = slide || document;
            const codeBlocks = scope.querySelectorAll('pre[class*="language-"] > code[class*="language-"]');

            for (const code of codeBlocks) {
                const pre = code.parentElement;
                resetNativeLineNumbers(pre);
                Prism.highlightElement(code);

                if (pre?.classList.contains('line-numbers') && Prism.plugins?.lineNumbers?.resize) {
                    Prism.plugins.lineNumbers.resize(pre);
                }
            }
        };

        const enhanceCurrentSlide = async (slide) => {
            highlightCodeInSlide(slide);
            await renderMermaidsInSlide(slide);
            updateMermaidDisplayBounds(slide);
            initSlideUI();
        };

        Reveal.initialize({
            hash: true,
            slideNumber: 'c/t',
            center: false,
            controls: false,
            plugins: [RevealMarkdown, RevealNotes, RevealMath.KaTeX, RevealZoom],
            katex: {
                local: '{{ base_url }}/js/vendor/katex',
                output: 'html',
                throwOnError: false,
                strict: false,
            },
            width: 960,
            height: 800,
            margin: 0.15,
            maxScale: 2.0,
        });

        Reveal.on('ready', event => {
            enhanceCurrentSlide(event.currentSlide);
        });

        Reveal.on('slideready', event => {
            enhanceCurrentSlide(event.currentSlide);
        });

        Reveal.on('slidechanged', event => {
            enhanceCurrentSlide(event.currentSlide);
        });

        window.addEventListener('resize', () => {
            updateMermaidDisplayBounds(Reveal.getCurrentSlide());
        });
    </script>
